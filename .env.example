# OKX 账户
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_API_PASSPHRASE=your_api_passphrase_here
OKX_MARGIN_MODE=cross

# AI 供应商列表（按顺序作为首选/备选）
AI_PROVIDER_ORDER=deepseek,openai

AI_PROVIDER_DEEPSEEK_API_KEY=your_api_key_here
AI_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_PROVIDER_DEEPSEEK_MODEL=deepseek-chat

AI_PROVIDER_OPENAI_API_KEY=your_fallback_api_key
AI_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_OPENAI_MODEL=gpt-4o-mini

# 控制台密码 (必需，仅在设置页使用)
CONSOLE_PASSWORD=your_secure_password_here

# 时区设置 (用于全局时间显示，格式: "+8", "-5" 等，范围 +14 至 -12)
TIMEZONE=+8

# Flask 配置 (建议进行修改)
FLASK_SECRET_KEY=change-this-in-production
FLASK_DEBUG=true

# 交易选项 (保持默认即可)
# 注：KLINE_DISPLAY_LIMIT 参数代表单级别下一次提供多少根 K 线。
# 降低可显著减少 Token 消耗，但会降低 AI 分析精准度；不建议超过 100。
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,DOGE/USDT
TRADING_INTERVAL_MINUTES=3
KLINE_DISPLAY_LIMIT=100

# Bark 通知（可选，仅推送到 Bark，不接飞书/钉钉/微信）
BARK_ENABLED=false
# 推荐写法：直接填 Bark App 里的完整推送地址
BARK_URL=https://api.day.app/your_device_key
# 或者使用拆分写法（二选一即可）
# BARK_SERVER_URL=https://api.day.app
# BARK_DEVICE_KEY=your_device_key
BARK_GROUP=OpenNOF1
BARK_LEVEL=active
# 可选：点击通知跳转到本机网页；如果手机打不开 localhost，可留空
BARK_OPEN_URL=
BARK_TIMEOUT_SECONDS=8
BARK_MAX_BODY_CHARS=3500

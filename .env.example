# OKX 账户
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_API_PASSPHRASE=your_api_passphrase_here
OKX_MARGIN_MODE=cross

# AI 提供商 1 (必需)
AI_1_API_KEY=your_api_key_here
AI_1_BASE_URL=https://api.deepseek.com/v1
AI_1_MODEL=deepseek-chat

# AI 提供商 2 (可选，故障转移)
# AI_2_API_KEY=your_fallback_api_key
# AI_2_BASE_URL=https://api.openai.com/v1
# AI_2_MODEL=gpt-4o-mini

# 控制台密码 (必需，仅在设置页使用)
CONSOLE_PASSWORD=your_secure_password_here

# 时区设置 (用于全局时间显示，格式: "+8", "-5" 等，范围 +14 至 -12)
TIMEZONE=+8

# Flask 配置 (建议进行修改)
FLASK_SECRET_KEY=change-this-in-production
FLASK_DEBUG=true

# 交易选项 (保持默认即可)
# 注：KLINE_DISPLAY_LIMIT 参数代表单级别下一次提供多少根 K 线。
# 降低可显著减少 Token 消耗，但会降低 AI 分析精准度；不建议超过 100。
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,DOGE/USDT
TRADING_INTERVAL_MINUTES=3
KLINE_DISPLAY_LIMIT=100
